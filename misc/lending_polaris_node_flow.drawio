        <mxCell id="p_application" value="08 Loan or BNPL Initiation&#xa;One-tap application or POS invoice/QR transaction starts" style="rounded=1;whiteSpace=wrap;html=0;arcSize=8;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="1215" width="620" height="88" as="geometry"/></mxCell>
