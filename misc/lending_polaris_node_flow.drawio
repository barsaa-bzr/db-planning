        <mxCell id="p_bnpl_transfer" value="12 BNPL Merchant Transfer&#xa;Customer deposit to merchant passive account, then POS approved callback" style="rounded=1;whiteSpace=wrap;html=0;arcSize=8;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="1755" width="620" height="88" as="geometry"/></mxCell>
        <mxCell id="p_repayment" value="13 Repayment Processing&#xa;QPay callback, inbound money to deposit, pay loan from deposit" style="rounded=1;whiteSpace=wrap;html=0;arcSize=8;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="1890" width="620" height="88" as="geometry"/></mxCell>
