        <mxCell id="p_config" value="01 System Configuration&#xa;Load productCode, brchCode, curCode, txnDefCode, dynamicData mappings" style="rounded=1;whiteSpace=wrap;html=0;arcSize=8;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="270" width="620" height="88" as="geometry"/></mxCell>
        <mxCell id="p_merchant" value="02 Merchant Onboarding&#xa;Create merchant, terminal, passive account and settlement account" style="rounded=1;whiteSpace=wrap;html=0;arcSize=8;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="405" width="620" height="88" as="geometry"/></mxCell>
        <mxCell id="p_register" value="03 Customer Registration and Login&#xa;OTP, session, PIN/biometric, customer profile starts pending" style="rounded=1;whiteSpace=wrap;html=0;arcSize=8;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="540" width="620" height="88" as="geometry"/></mxCell>
        <mxCell id="p_kyc" value="04 DAN Authorization and KYC Capture&#xa;DAN consent, HUR fetch, contact/address/files, manual review if needed" style="rounded=1;whiteSpace=wrap;html=0;arcSize=8;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#0f172a;fontSize=12;fontStyle=1;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="675" width="620" height="88" as="geometry"/></mxCell>
