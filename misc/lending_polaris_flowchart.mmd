flowchart TD
    admin["Admin configures Polaris product/transaction/dynamic field configs"]
    merchant["Merchant onboarding\nmerchant_profiles, pos_terminals, polaris_accounts\nAPIs: tmm/insertMerchant, tsd/createTsdTerminal"]
    register["Customer registration + OTP\nusers, customer_profiles, otp_sessions"]
    dan["DAN authorization\ndan_verifications"]
    cif["Create/update Polaris CIF\ncif/createPerson, cif/updatePerson\nstore polaris_cust_code"]
    deposit["Create/open customer deposit account\ncasa/createAccount, casa/openAccountStatus\nstore acntCode in polaris_accounts + customer_deposit_accounts"]
    kyc["KYC details sync\nkyc_* tables + cif/updatePerson dynamicData"]
    score["Credit scoring\nSain FICO + custom score\nsync risk fields to Polaris"]
    limit["Create local loan limit\nloan_limits"]
    line["Create/open Polaris line loan account\nline/createAccount, line/openAccount\nlinked to customer deposit account"]

    app{"Customer starts loan"}
    onetap["One-tap loan application\nloan_applications"]
    bnpl["BNPL invoice / QR\npos_payment_invoices, pos_qr_codes, pos_transactions"]
    reserve["Reserve line amount under lock\ncredit_limit_reservations\navailable = line - utilized - reserved"]
    approve{"Approve?"}
    reject["Reject/cancel\nrelease reservation\nwrite audit_logs"]
    contract["Contract + pending_core_setup\nloan_contracts optional"]
    child["Create/open child loan account\nloan/createAccount, loan/openAccount"]
    schedule["Calculate/create schedule\nloan/calculateNrsSchedule, loan/createNrsSchedule\nlocal schedule must match Polaris"]
    link["Link child loan to line\nline/linkLineAccountToLoan"]
    grant["Grant loan non-cash\nloan/grantLoanNonCash\nchild loan -> customer deposit\nsave jrno + ledger_journals"]

    channel{"Product type"}
    oneTapDone["One-tap success\nloan active, application disbursed\nreservation consumed"]
    bnplTransfer["BNPL merchant transfer\ntllrcasa/internalCasaTransaction\ncustomer deposit -> merchant passive"]
    posApproved["POS approved callback only after transfer\npos_terminal_callbacks"]
    settlement["Merchant settlement\nmerchant passive -> merchant settlement/bank account"]

    qpay["Repayment invoice\nqpay_repayment_invoices"]
    callback["QPay callback receive\nunique qpay_payment_id\nignore duplicate callbacks"]
    inbound["Inbound repayment money\nbank/QPay pool -> customer deposit\nledger_journals + jrno"]
    repay["Pay loan from customer deposit\nloan/nonCashLoanPayment or loanPaymentTxnNonCash"]
    allocate["Lock schedules + allocate repayment\nrepayment_allocations\nprevent overpayment"]
    closeDecision{"Final payment?"}
    closeLoan["Close loan\nloan/getLoanClosingAccountDetail, loan/nonCashCloseAccount\nreduce utilized line"]
    activeLoan["Loan remains active\nnext installment or overdue handling"]

    timeout["Any Polaris timeout/interruption\nstatus = pending_reconcile"]
    reconcile["Reconcile before retry\ngen/getTmwJournalList, gen/getAccountStatement, account details"]
    matched{"Polaris truth found?"}
    markSuccess["Store jrno, mark succeeded, continue"]
    retry["No match and safe to retry\nreuse same idempotency_key"]
    manual["Multiple/ambiguous matches\ndead_letter + finance manual review"]
    reverse["Refund/reversal\ngen/doReverseTxn or gen/undoTransaction\none reversal per original jrno"]
    audit["Audit + ledger rules\naudit_logs for status changes\npolaris_api_logs for calls\nsystem_event_logs for runtime\nledger_journals for financial facts"]

    admin --> merchant
    admin --> register
    register --> dan --> cif --> deposit --> kyc --> score --> limit --> line --> app
    app --> onetap --> reserve
    app --> bnpl --> reserve
    reserve --> approve
    approve -- no --> reject
    approve -- yes --> contract --> child --> schedule --> link --> grant --> channel
    channel -- one_tap --> oneTapDone
    channel -- bnpl --> bnplTransfer --> posApproved --> settlement
    oneTapDone --> qpay
    posApproved --> qpay
    qpay --> callback --> inbound --> repay --> allocate --> closeDecision
    closeDecision -- yes --> closeLoan
    closeDecision -- no --> activeLoan

    child -. timeout .-> timeout
    schedule -. timeout .-> timeout
    link -. timeout .-> timeout
    grant -. timeout .-> timeout
    bnplTransfer -. timeout .-> timeout
    inbound -. timeout .-> timeout
    repay -. timeout .-> timeout
    closeLoan -. timeout .-> timeout
    settlement -. timeout .-> timeout
    timeout --> reconcile --> matched
    matched -- yes --> markSuccess
    matched -- no, safe --> retry
    matched -- ambiguous --> manual
    retry --> reconcile
    markSuccess --> audit
    reverse --> reconcile

    audit --- admin
    audit --- merchant
    audit --- register
    audit --- reserve
    audit --- grant
    audit --- repay
