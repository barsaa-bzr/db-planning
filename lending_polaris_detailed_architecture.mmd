flowchart LR
    subgraph UI["UI channels"]
        adminUI["Admin / Back-office\nConfigure products, transaction codes,\nmanual reviews, service pause"]
        customerUI["Customer mobile app\nRegister, DAN consent, KYC,\noffer, one-tap loan, repayment"]
        merchantUI["Merchant POS / portal\nCreate BNPL invoice, QR,\ncallbacks, refunds, settlement view"]
        financeUI["Finance ops / audit UI\nReconciliation, dead-letter,\nreports, exports"]
    end

    subgraph APP["Backend services"]
        configSvc["Configuration service\nloads Polaris product/txn/dynamic fields"]
        authSvc["Auth & session service\nOTP, PIN, biometric, authorization"]
        kycSvc["KYC orchestration\nDAN, HUR, files, CIF sync"]
        scoreSvc["Scoring engine\nFICO + custom score + explainability"]
        limitSvc["Limit & line manager\nrow lock, reserve, consume, release"]
        loanSvc["Loan core orchestrator\nloan_core_steps strict order"]
        bnplSvc["BNPL/POS processor\ninvoice lock, QR, merchant transfer"]
        repaySvc["Repayment processor\nQPay callback guard, allocation lock"]
        reconSvc["Reconciliation scheduler\njournal, statement, balance matching"]
    end

    subgraph DB["Core database"]
        configDB["polaris_product_configs\npolaris_transaction_configs\npolaris_dynamic_field_mappings"]
        userDB["users, customer_profiles\nOTP/session/PIN/biometric tables"]
        kycDB["dan_verifications, kyc_*\nhur_data_snapshots, sain_score_requests"]
        scoreDB["credit_score_results\ncredit_scoring_factors\nloan_limits"]
        lineDB["customer_deposit_accounts\ncredit_line_accounts\ncredit_limit_reservations"]
        loanDB["loan_applications, loans\nrepayment_schedules\nloan_core_steps"]
        posDB["merchant_profiles, pos_terminals\npos_payment_invoices, pos_transactions\nmerchant_settlements"]
        repayDB["qpay_repayment_invoices\nqpay_repayment_callbacks\nrepayment_transactions, allocations"]
        ledgerDB["ledger_journals, ledger_entries\npolaris_accounts"]
        auditDB["audit_logs\nsystem_event_logs\npolaris_api_logs\npolaris_operation_attempts\npolaris_sync_queue"]
    end

    subgraph EXT["External integrations"]
        danAPI["DAN identity authority"]
        hurAPI["HUR data services"]
        sainAPI["Sain/FICO scoring"]
        qpayAPI["QPay invoices + callbacks"]
        posAPI["Merchant POS terminal"]
        polarisCIF["Polaris CIF\ncif/createPerson, cif/updatePerson"]
        polarisCASA["Polaris CASA\ncasa/createAccount, openAccountStatus"]
        polarisLine["Polaris LINE\nline/createAccount, openAccount,\nadjustLineAccountLimit,\nlinkLineAccountToLoan"]
        polarisLoan["Polaris LOAN\nloan/createAccount, openAccount,\ncalculate/createNrsSchedule,\ngrantLoanNonCash,\nnonCashLoanPayment,\nnonCashCloseAccount"]
        polarisTxn["Polaris TXN/GEN\ntllrcasa/internalCasaTransaction,\ngen/getTmwJournalList,\ngen/getAccountStatement,\ngen/doReverseTxn, gen/undoTransaction"]
    end

    subgraph CTRL["Controls and invariants"]
        idemp["Idempotency key per operation\nsame key on retry"]
        outbox["Polaris write calls only through\npolaris_sync_queue + attempts"]
        pending["Timeout != failed\npending_reconcile until truth proven"]
        reservation["Limit reservation before approval/grant\navailable = line - utilized - reserved"]
        locks["POS invoice lock\nQPay duplicate guard\nschedule allocation lock"]
        reversal["One reversal per original jrno"]
        audit["audit_logs for business/security/financial\nsystem_event_logs for runtime\nledger_journals for financial truth"]
    end

    adminUI --> configSvc --> configDB
    customerUI --> authSvc --> userDB
    customerUI --> kycSvc --> kycDB
    kycSvc --> danAPI
    kycSvc --> hurAPI
    kycSvc --> polarisCIF
    kycSvc --> polarisCASA
    scoreSvc --> sainAPI
    scoreSvc --> scoreDB
    scoreSvc --> polarisCIF
    limitSvc --> lineDB
    limitSvc --> polarisLine
    customerUI --> loanSvc
    merchantUI --> bnplSvc
    loanSvc --> loanDB
    loanSvc --> polarisLoan
    loanSvc --> ledgerDB
    bnplSvc --> posDB
    bnplSvc --> polarisTxn
    bnplSvc --> ledgerDB
    customerUI --> repaySvc
    repaySvc --> qpayAPI
    repaySvc --> repayDB
    repaySvc --> polarisLoan
    repaySvc --> ledgerDB
    merchantUI --> posAPI
    financeUI --> reconSvc
    reconSvc --> polarisTxn
    reconSvc --> auditDB
    reconSvc --> ledgerDB

    loanSvc -.-> idemp
    bnplSvc -.-> idemp
    repaySvc -.-> idemp
    loanSvc -.-> outbox
    bnplSvc -.-> outbox
    repaySvc -.-> outbox
    reconSvc -.-> pending
    limitSvc -.-> reservation
    bnplSvc -.-> locks
    repaySvc -.-> locks
    reconSvc -.-> reversal
    auditDB -.-> audit
